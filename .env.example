# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# The ID of the Discord server (right-click server → Copy Server ID)
DISCORD_GUILD_ID=

# The ID of the private channel where discussions happen
DISCORD_CHANNEL_ID=

# Your Discord user ID (right-click your name → Copy User ID)
DISCORD_USER_ID=

# Cloud API keys — fill in whichever services you want replicants to use
# Leave blank if you're running everything locally
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional: webhook URLs (auto-created by setup_webhooks.py — leave blank to auto-setup)
WEBHOOK_BOB=
WEBHOOK_RIKER=
WEBHOOK_BILL=
WEBHOOK_MILO=
WEBHOOK_HOMER=

# Vector database persistence directory
CHROMA_PERSIST_DIR=./chroma_db
