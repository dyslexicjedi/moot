{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.py)|Write(*.py)",
            "command": "cd $CLAUDE_PROJECT_DIR && source .venv/bin/activate && pytest --tb=short -q 2>&1",
            "timeout": 60,
            "statusMessage": "Running pytest..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh",
            "timeout": 30,
            "statusMessage": "Checking tests before commit..."
          }
        ]
      }
    ]
  }
}
